# ==== Shared ====
NODE_ENV=development
AWS_REGION=ap-northeast-2

# ==== Database (packages/db, backend-api, chatbot-service, order-consumer) ====
DATABASE_URL=postgresql://ringdog:ringdog@localhost:5432/ringdog?schema=public

# ==== Auth (backend-api) ====
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=1h

# ==== Kafka / MSK (backend-api, order-consumer) ====
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ringdog
KAFKA_TOPIC_ORDERS=ringdog.orders
KAFKA_TOPIC_CATALOG=ringdog.catalog
KAFKA_CONSUMER_GROUP_ORDERS=ringdog-order-consumer

# ==== OpenSearch (backend-api) ====
OPENSEARCH_NODE=http://localhost:9200
OPENSEARCH_INDEX_PRODUCTS=products

# ==== Bedrock (chatbot-service) ====
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_MOCK_MODE=true

# ==== Service ports ====
FRONTEND_PORT=3000
BACKEND_API_PORT=4000
CHATBOT_SERVICE_PORT=4001
ORDER_CONSUMER_HEALTH_PORT=4002

# ==== Frontend -> backend ====
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_CHATBOT_API_BASE_URL=http://localhost:4001
CORS_ORIGIN=http://localhost:3000

# ==== Datadog Agent (dd-trace, all backend services) + RUM (frontend) ====
# DD_ENV/DD_SITE are shared by both; DD_RUM_* are plain (not NEXT_PUBLIC_)
# env vars read server-side by src/app/layout.tsx and passed into the
# client at request time — see datadogRum.ts for why.
DD_ENV=local
DD_SERVICE=
DD_VERSION=0.1.0
DD_AGENT_HOST=localhost
DD_TRACE_AGENT_PORT=8126
DD_LOGS_INJECTION=true
DD_CIVISIBILITY_ENABLED=false
DD_SITE=datadoghq.com
DD_RUM_APPLICATION_ID=
DD_RUM_CLIENT_TOKEN=

# ==== Demo coupon ====
DEMO_COUPON_CODE=RINGDOG100
